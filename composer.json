{
  "name": "leboncoin/scraper",
  "description": "Scraper automatisé pour annonces Leboncoin - Disques de musculation",
  "type": "project",
  "license": "MIT",
  "authors": [
    {
      "name": "Manus AI",
      "email": "dev@manus.ai"
    }
  ],
  "require": {
    "php": "^8.1",
    "friendsofphp/goutte": "^4.0",
    "symfony/dom-crawler": "^6.0",
    "guzzlehttp/guzzle": "^7.0",
    "monolog/monolog": "^3.0",
    "vlucas/phpdotenv": "^5.0",
    "longman/telegram-bot": "^0.80"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "Leboncoin\\Scraper\\": "src/"
    }
  },
  "scripts": {
    "scrape": "php bin/scraper.php",
    "test": "phpunit"
  },
  "config": {
    "allow-plugins": {
      "composer/package-versions-deprecated": true
    }
  }
}
